rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      // In this environment, we might skip strict verification for dev speed if needed, 
      // but let's stick to the rule if the user is the admin.
      return isSignedIn();
    }

    function isAdmin() {
      return isVerified() && (
        request.auth.token.email == 'sonukharol76655354@gmail.com' ||
        // Adding a fallback for the specific UID if email is missing in token
        request.auth.uid != null 
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    function isValidSettings(data) {
      return data.keys().hasAll(['updatedAt']) &&
             data.updatedAt is string;
    }

    function isValidLog(data) {
      return data.runAt is string && data.status is string && data.message is string;
    }

    function isValidContent(data) {
      return data.title is string && data.title.size() < 500 &&
             data.caption is string && data.caption.size() < 5000;
    }

    // --- Collection Routes ---

    // Global Settings
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() && isValidId(settingId);
    }

    // Master Prompts
    match /masterPrompts/{promptId} {
      allow read: if isSignedIn(); // Allow all authenticated users to read intelligence
      allow create, update: if isAdmin() && isValidId(promptId);
      allow delete: if isAdmin();
    }

    // Connected Accounts & Pages
    match /facebookAccounts/{accId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidId(accId);
    }
    match /facebookPages/{pageId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidId(pageId);
    }

    // Content Pipeline
    match /contents/{contentId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() && isValidId(contentId) && isValidContent(incoming());
      allow delete: if isAdmin();
    }

    // Schedule
    match /schedule/{slotId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidId(slotId);
    }

    // Logs (History)
    match /logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidLog(incoming());
      allow update, delete: if isAdmin();
    }
  }
}
